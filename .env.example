# United MileagePlus
UNITED_MP_NUMBER=your_mp_number
UNITED_PASSWORD=your_password

# American AAdvantage
AA_NUMBER=your_aa_number
AA_PASSWORD=your_aa_password

# Storage
DATA_DIR=~/.award_scout

# Browser
HEADLESS=true
BROWSER_TIMEOUT_MS=60000

# Monitoring
WATCH_ORIGIN=SFO
WATCH_DESTINATION=BJS
WATCH_START_DATE=2026-09-01
WATCH_END_DATE=2026-09-30
WATCH_CABIN=business
WATCH_MAX_MILES=110000

# Notifications: ntfy.sh (optional)
NTFY_TOPIC=your_ntfy_topic
NTFY_SERVER=https://ntfy.sh

# Notifications: Email (optional, for award alerts)
# 163.com example — use SMTP authorization code, NOT login password
EMAIL_TO=xdtaosz@163.com
EMAIL_FROM=xdtaosz@163.com
EMAIL_SMTP_HOST=smtp.163.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=xdtaosz@163.com
EMAIL_SMTP_PASSWORD=your_smtp_auth_code
